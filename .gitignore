# ─────────────────────────────────────────────────────────────────────────────
# @notifycode/hash-it — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
out/

# ── Bun ───────────────────────────────────────────────────────────────────────
bun.lockb
.bun-cache/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
*.d.ts.map

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-error.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/

# ── Package tarballs ──────────────────────────────────────────────────────────
*.tgz
*.tar.gz

# ── Caches ────────────────────────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
.parcel-cache/
.turbo/

# ── IDE & editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux (Fedora / GNOME)
.directory
.Trash-*
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Docs build ────────────────────────────────────────────────────────────────
docs/api/
docs/.vitepress/cache/
docs/.vitepress/dist/

*.zip
*.orig
*.bak
.temp/
tmp/
